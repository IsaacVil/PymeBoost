# ============================================================================
#  PymeBoost backend — PERFIL LOCAL (MVP). Copiar a backend/.env y ajustar.
#  Mismos nombres de variable que el diseño cloud (README §2.3), mapeados a
#  equivalentes locales (docs/mvpspec.md §2). Las cloud vars quedan vacías.
# ============================================================================

# --- Core ---
ENVIRONMENT=development
LOG_LEVEL=INFO
API_VERSION=v1
USE_MOCKS=true

# --- Database (docker-compose Postgres+pgvector) ---
DATABASE_URL=postgresql://pymeboost:pymeboost@localhost:5432/pymeboost
DATABASE_POOL_SIZE=5

# --- Auth: mock JWT local (reemplaza Auth0) ---
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=180

# --- CORS (orígenes separados por coma) ---
CORS_ORIGINS=http://localhost:3000

# --- Cloud vars (opcionales en local; dejar vacías) ---
AUTH0_DOMAIN=
JWKS_URL=
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
PUBSUB_TOPIC_CONTRACTS=
REDIS_URL=
KMS_KEY_NAME=
LANGRAPH_API_KEY=
