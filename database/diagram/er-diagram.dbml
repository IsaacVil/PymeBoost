// 3. ADVISOR DOMAIN
// ============================================================

Table PB_Promises {
  id          uuid        [pk, default: `gen_random_uuid()`]
  advisorId   uuid        [not null, ref: > PB_Advisors.id]
  promiseText text        [not null]
  isActive    boolean     [not null, default: true]
  createdAt   timestamptz [not null, default: `now()`]
  updatedAt   timestamptz [not null, default: `now()`]
}

Table PB_PromiseSubIndustryScores {
  id            uuid         [pk, default: `gen_random_uuid()`]
  promiseId     uuid         [not null, ref: > PB_Promises.id]
  subIndustryId uuid         [not null, ref: > PB_SubIndustries.id]
  score         numeric(7,4) [not null]
  createdAt     timestamptz  [not null, default: `now()`]

  indexes {
    (promiseId, subIndustryId) [unique]
  }
}

// ============================================================
// 4. PYME DOMAIN
// ============================================================

Table PB_QuestionCatalog {
  id           uuid        [pk, default: `gen_random_uuid()`]
  questionText text        [not null]
  displayOrder smallint    [not null, default: 0]
  isActive     boolean     [not null, default: true]
  createdAt    timestamptz [not null, default: `now()`]
}

Table PB_QuestionSubIndustries {
  questionId    uuid [not null, ref: > PB_QuestionCatalog.id]
  subIndustryId uuid [not null, ref: > PB_SubIndustries.id]

  indexes {
    (questionId, subIndustryId) [pk]
  }
}

Table PB_NeedsAssessments {
  id            uuid        [pk, default: `gen_random_uuid()`]
  pymeId        uuid        [not null, ref: > PB_Pymes.id]
  versionNumber integer     [not null]
  isActive      boolean     [not null, default: true]
  needsVector   text        [note: 'pgvector vector(32)']
  createdAt     timestamptz [not null, default: `now()`]

  indexes {
    (pymeId, versionNumber) [unique]
  }
}

Table PB_NeedsAssessmentAnswers {
  id                uuid     [pk, default: `gen_random_uuid()`]
  needsAssessmentId uuid     [not null, ref: > PB_NeedsAssessments.id]
  questionId        uuid     [not null, ref: > PB_QuestionCatalog.id]
  rating            smallint [not null]

  indexes {
    (needsAssessmentId, questionId) [unique]
  }
}

Table PB_NeedsAssessmentSubIndustries {
  id                uuid         [pk, default: `gen_random_uuid()`]
  needsAssessmentId uuid         [not null, ref: > PB_NeedsAssessments.id]
  subIndustryId     uuid         [not null, ref: > PB_SubIndustries.id]
  avgRating         numeric(5,4) [not null]
  normalizedScore   numeric(6,5) [not null]

  indexes {
    (needsAssessmentId, subIndustryId) [unique]
  }
}

// ============================================================
// 5. AI DOMAIN
// ============================================================

Table PB_Documents {
  id                      uuid         [pk, default: `gen_random_uuid()`]
  gcsBucket               varchar(100) [not null]
  gcsObjectPath           varchar(500) [not null]
  originalFilename        varchar(255) [not null]
  mimeType                varchar(100) [not null]
  sizeBytes               bigint
  documentTypeId          uuid         [not null, ref: > PB_DocumentTypes.id]
  documentStatusId        uuid         [not null, ref: > PB_DocumentStatus.id]
  uploadedByAccountTypeId uuid         [not null, ref: > PB_AccountTypes.id]
  uploadedByPymeId        uuid         [ref: > PB_Pymes.id]
  uploadedByAdvisorId     uuid         [ref: > PB_Advisors.id]
  uploadedAt              timestamptz  [not null, default: `now()`]
}

Table PB_UseCases {
  id                uuid          [pk, default: `gen_random_uuid()`]
  advisorId         uuid          [not null, ref: > PB_Advisors.id]
  documentId        uuid          [not null, ref: > PB_Documents.id]
  title             varchar(200)
  industryId        uuid          [ref: > PB_Industries.id]
  companySizeId     uuid          [ref: > PB_CompanySizes.id]
  metricUsed        varchar(100)
  metricValueTypeId uuid          [ref: > PB_MetricValueTypes.id]
  metricBefore      numeric(14,4)
  metricAfter       numeric(14,4)
  useCaseStatusId   uuid          [not null, ref: > PB_UseCaseStatus.id]
  processedAt       timestamptz
  createdAt         timestamptz   [not null, default: `now()`]
  updatedAt         timestamptz   [not null, default: `now()`]
}

Table PB_DocumentBlocks {
  id                 uuid        [pk, default: `gen_random_uuid()`]
  useCaseId          uuid        [not null, ref: > PB_UseCases.id]
  advisorId          uuid        [not null, ref: > PB_Advisors.id]
  thematicCategoryId uuid        [not null, ref: > PB_ThematicCategories.id]
  industryId         uuid        [ref: > PB_Industries.id]
  content            text        [not null]
  contentHash        varchar(64) [not null]
  embedding          text        [not null, note: 'pgvector vector(768)']
  createdAt          timestamptz [not null, default: `now()`]

  indexes {
    (advisorId, contentHash) [unique]
  }
}

Table PB_RecommendationSets {
  id            uuid        [pk, default: `gen_random_uuid()`]
  pymeId        uuid        [not null, ref: > PB_Pymes.id]
  versionNumber integer     [not null]
  isActive      boolean     [not null, default: true]
  generatedAt   timestamptz [not null, default: `now()`]

  indexes {
    (pymeId, versionNumber) [unique]
  }
}

Table PB_RecommendationItems {
  id                  uuid          [pk, default: `gen_random_uuid()`]
  recommendationSetId uuid          [not null, ref: > PB_RecommendationSets.id]
  advisorId           uuid          [not null, ref: > PB_Advisors.id]
  rank                smallint      [not null]
  compositeScore      numeric(8,6)  [not null]
  semanticScore       numeric(8,6)
  needsAlignmentScore numeric(8,6)
  reputationScore     numeric(12,8)
  createdAt           timestamptz   [not null, default: `now()`]

  indexes {
    (recommendationSetId, advisorId) [unique]
    (recommendationSetId, rank)      [unique]
  }
}

// ============================================================
// 6. MATCHING DOMAIN
// ============================================================

Table PB_Matches {
  id            uuid        [pk, default: `gen_random_uuid()`]
  pymeId        uuid        [not null, ref: > PB_Pymes.id]
  advisorId     uuid        [not null, ref: > PB_Advisors.id]
  matchStatusId uuid        [not null, ref: > PB_MatchStatus.id]
  createdAt     timestamptz [not null, default: `now()`]

  indexes {
    (pymeId, advisorId) [unique]
  }
}

Table PB_MatchStatusHistory {
  matchId       uuid        [not null, ref: > PB_Matches.id]
  matchStatusId uuid        [not null, ref: > PB_MatchStatus.id]
  occurredAt    timestamptz [not null, default: `now()`]

  indexes {
    (matchId, matchStatusId) [pk]
  }
}

// ============================================================
// 7. COMMUNICATION DOMAIN
// ============================================================

Table PB_ChatSessions {
  id        uuid        [pk, default: `gen_random_uuid()`]
  matchId   uuid        [not null, unique, ref: > PB_Matches.id]
  isActive  boolean     [not null, default: true]
  createdAt timestamptz [not null, default: `now()`]
}

Table PB_Messages {
  id                  uuid        [pk, default: `gen_random_uuid()`]
  chatSessionId       uuid        [not null, ref: > PB_ChatSessions.id]
  messageTypeId       uuid        [not null, ref: > PB_MessageTypes.id]
  senderAccountTypeId uuid        [ref: > PB_AccountTypes.id]
  senderPymeId        uuid        [ref: > PB_Pymes.id]
  senderAdvisorId     uuid        [ref: > PB_Advisors.id]
  content             text        [not null]
  createdAt           timestamptz [not null, default: `now()`]
}

Table PB_MessageStatusHistory {
  messageId       uuid        [not null, ref: > PB_Messages.id]
  messageStatusId uuid        [not null, ref: > PB_MessageStatus.id]
  occurredAt      timestamptz [not null, default: `now()`]

  indexes {
    (messageId, messageStatusId) [pk]
  }
}

Table PB_BlockedMessageAttempts {
  id                       uuid        [pk, default: `gen_random_uuid()`]
  chatSessionId            uuid        [not null, ref: > PB_ChatSessions.id]
  senderPymeId             uuid        [ref: > PB_Pymes.id]
  senderAdvisorId          uuid        [ref: > PB_Advisors.id]
  attemptedContent         text        [not null]
  blockedContentCategoryId uuid        [not null, ref: > PB_BlockedContentCategories.id]
  createdAt                timestamptz [not null, default: `now()`]
}

// ============================================================
// 8. CONTRACT DOMAIN
// ============================================================

Table PB_Contracts {
  id               uuid        [pk, default: `gen_random_uuid()`]
  matchId          uuid        [not null, unique, ref: > PB_Matches.id]
  contractStatusId uuid        [not null, ref: > PB_ContractStatus.id]
  currentVersionId uuid        [ref: > PB_ContractVersions.id]
  createdAt        timestamptz [not null, default: `now()`]
  updatedAt        timestamptz [not null, default: `now()`]
}

Table PB_ContractVersions {
  id                      uuid          [pk, default: `gen_random_uuid()`]
  contractId              uuid          [not null, ref: > PB_Contracts.id]
  versionNumber           integer       [not null]
  proposedByAccountTypeId uuid          [not null, ref: > PB_AccountTypes.id]
  proposedByPymeId        uuid          [ref: > PB_Pymes.id]
  proposedByAdvisorId     uuid          [ref: > PB_Advisors.id]
  contractVersionStatusId uuid          [not null, ref: > PB_ContractVersionStatus.id]
  implementationBudget    numeric(14,2) [not null]
  monthlyRetainer         numeric(14,2) [not null]
  startDate               date          [not null]
  endDate                 date          [not null]
  commissionPct           numeric(7,4)  [not null]
  mainObjective           text          [not null]
  advisorResultProfit     numeric(14,2)
  createdAt               timestamptz   [not null, default: `now()`]

  indexes {
    (contractId, versionNumber) [unique]
  }
}

Table PB_ContractMetrics {
  id                uuid          [pk, default: `gen_random_uuid()`]
  contractVersionId uuid          [not null, ref: > PB_ContractVersions.id]
  name              varchar(100)  [not null]
  metricValueTypeId uuid          [not null, ref: > PB_MetricValueTypes.id]
  target            numeric(14,4) [not null]
  baselineValue     numeric(14,4)
  createdAt         timestamptz   [not null, default: `now()`]

  indexes {
    (contractVersionId, name) [unique]
  }
}

Table PB_ContractRoadmapPhases {
  id                uuid         [pk, default: `gen_random_uuid()`]
  contractVersionId uuid         [not null, ref: > PB_ContractVersions.id]
  phaseOrder        smallint     [not null]
  name              varchar(100) [not null]
  description       text
  completed         boolean      [not null, default: false]
  completedAt       timestamptz

  indexes {
    (contractVersionId, phaseOrder) [unique]
  }
}

Table PB_PhaseMetricTargets {
  id               uuid         [pk, default: `gen_random_uuid()`]
  phaseId          uuid         [not null, ref: > PB_ContractRoadmapPhases.id]
  contractMetricId uuid         [not null, ref: > PB_ContractMetrics.id]
  targetPct        numeric(7,4) [not null]

  indexes {
    (phaseId, contractMetricId) [unique]
  }
}

Table PB_ContractSubPhases {
  id          uuid         [pk, default: `gen_random_uuid()`]
  phaseId     uuid         [not null, ref: > PB_ContractRoadmapPhases.id]
  name        varchar(100) [not null]
  description text
  completed   boolean      [not null, default: false]
  completedAt timestamptz
}

// ============================================================
// 9. PROJECT DOMAIN
// ============================================================

Table PB_Projects {
  id                uuid        [pk, default: `gen_random_uuid()`]
  contractVersionId uuid        [not null, unique, ref: > PB_ContractVersions.id]
  projectStatusId   uuid        [not null, ref: > PB_ProjectStatus.id]
  completedAt       timestamptz
  createdAt         timestamptz [not null, default: `now()`]
  updatedAt         timestamptz [not null, default: `now()`]
}

Table PB_ProjectHealthHistory {
  id                    uuid         [pk, default: `gen_random_uuid()`]
  projectId             uuid         [not null, ref: > PB_Projects.id]
  projectHealthStatusId uuid         [not null, ref: > PB_ProjectHealthStatus.id]
  completedSubPhases    smallint     [not null]
  totalSubPhases        smallint     [not null]
  healthScore           numeric(8,2) [not null]
  timeProgressRatio     numeric(6,5) [not null]
  recordedAt            timestamptz  [not null, default: `now()`]
}

Table PB_ProjectKpiValidations {
  id                  uuid          [pk, default: `gen_random_uuid()`]
  projectId           uuid          [not null, ref: > PB_Projects.id]
  contractMetricId    uuid          [not null, ref: > PB_ContractMetrics.id]
  metricsBefore       numeric(14,4) [not null]
  metricsAfter        numeric(14,4) [not null]
  finalImprovementPct numeric(7,4)  [not null]
  met                 boolean       [not null]
  validatedAt         timestamptz   [not null, default: `now()`]

  indexes {
    (projectId, contractMetricId) [unique]
  }
}

// ============================================================
// 10. REVIEW DOMAIN
// ============================================================

Table PB_Reviews {
  id                    uuid         [pk, default: `gen_random_uuid()`]
  projectId             uuid         [not null, ref: > PB_Projects.id]
  reviewerAccountTypeId uuid         [not null, ref: > PB_AccountTypes.id]
  reviewerPymeId        uuid         [ref: > PB_Pymes.id]
  reviewerAdvisorId     uuid         [ref: > PB_Advisors.id]
  subjectAccountTypeId  uuid         [not null, ref: > PB_AccountTypes.id]
  subjectPymeId         uuid         [ref: > PB_Pymes.id]
  subjectAdvisorId      uuid         [ref: > PB_Advisors.id]
  rating                numeric(3,1) [not null]
  comment               text
  createdAt             timestamptz  [not null, default: `now()`]

  indexes {
    (projectId, reviewerAccountTypeId) [unique]
  }
}

// ============================================================
// 11. NOTIFICATION DOMAIN
// ============================================================

Table PB_Notifications {
  id                     uuid         [pk, default: `gen_random_uuid()`]
  recipientAccountTypeId uuid         [not null, ref: > PB_AccountTypes.id]
  recipientPymeId        uuid         [ref: > PB_Pymes.id]
  recipientAdvisorId     uuid         [ref: > PB_Advisors.id]
  notificationTypeId     uuid         [not null, ref: > PB_NotificationTypes.id]
  title                  varchar(200) [not null]
  body                   text
  payload                jsonb        [not null]
  relatedEntityType      varchar(100)
  relatedEntityId        uuid
  isRead                 boolean      [not null, default: false]
  readAt                 timestamptz
  createdAt              timestamptz  [not null, default: `now()`]
}

Table PB_NotificationDeliveries {
  id                           uuid         [pk, default: `gen_random_uuid()`]
  notificationId               uuid         [not null, ref: > PB_Notifications.id]
  notificationChannelId        uuid         [not null, ref: > PB_NotificationChannels.id]
  notificationDeliveryStatusId uuid         [not null, ref: > PB_NotificationDeliveryStatus.id]
  errorMessage                 varchar(255)

  indexes {
    (notificationId, notificationChannelId) [unique]
  }
}

Table PB_NotificationDeliveryStatusHistory {
  deliveryId                   uuid        [not null, ref: > PB_NotificationDeliveries.id]
  notificationDeliveryStatusId uuid        [not null, ref: > PB_NotificationDeliveryStatus.id]
  occurredAt                   timestamptz [not null, default: `now()`]

  indexes {
    (deliveryId, notificationDeliveryStatusId) [pk]
  }
}

Table PB_NotificationPreferences {
  id                    uuid        [pk, default: `gen_random_uuid()`]
  ownerAccountTypeId    uuid        [not null, ref: > PB_AccountTypes.id]
  ownerPymeId           uuid        [ref: > PB_Pymes.id]
  ownerAdvisorId        uuid        [ref: > PB_Advisors.id]
  notificationTypeId    uuid        [not null, ref: > PB_NotificationTypes.id]
  notificationChannelId uuid        [not null, ref: > PB_NotificationChannels.id]
  enabled               boolean     [not null, default: true]
  createdAt             timestamptz [not null, default: `now()`]
  updatedAt             timestamptz [not null, default: `now()`]

  indexes {
    (ownerPymeId, notificationTypeId, notificationChannelId)    [unique]
    (ownerAdvisorId, notificationTypeId, notificationChannelId) [unique]
  }
}

// ============================================================
// 12. EVENT DOMAIN
// ============================================================

Table PB_DomainEvents {
  id            uuid         [pk, default: `gen_random_uuid()`]
  eventTypeId   uuid         [not null, ref: > PB_EventTypes.id]
  aggregateType varchar(100)
  aggregateId   uuid
  payload       jsonb        [not null]
  occurredAt    timestamptz  [not null, default: `now()`]
  publishedAt   timestamptz
  createdAt     timestamptz  [not null, default: `now()`]
}

// ============================================================
// 13. LOGS (PV_ prefix)
// ============================================================

Table PV_MediaTypes {
  mediaTypeId serial      [pk]
  name        varchar(30)
  playerImpl  varchar(100)
}

Table PV_MediaFiles {
  mediafileid  serial       [pk]
  mediapath    varchar(500) [not null]
  deleted      boolean      [not null, default: false]
  lastupdate   timestamptz  [not null, default: `now()`]
  userid       varchar(64)  [not null]
  mediatypeid  int          [not null, ref: > PV_MediaTypes.mediaTypeId]
  sizeMB       numeric(10,3)
  encoding     varchar(100)
  samplerate   varchar(50)
  languagecode varchar(10)
}

Table PV_LogTypes {
  logtypeid       serial       [pk]
  name            varchar(45)  [not null]
  ref1description varchar(120) [not null]
  ref2description varchar(120) [not null]
  val1description varchar(120) [not null]
  val2description varchar(120) [not null]
}

Table PV_LogSource {
  logsourceid serial      [pk]
  name        varchar(45) [not null]
}

Table PV_LogSeverity {
  logseverityid serial      [pk]
  name          varchar(45) [not null]
}

Table PV_Logs {
  logid         serial       [pk]
  description   varchar(120) [not null]
  name          varchar(50)  [not null]
  posttime      timestamp    [not null, default: `now()`]
  computer      varchar(45)  [not null]
  trace         varchar(200) [not null]
  referenceid1  bigint
  referenceid2  bigint
  checksum      varchar(250) [not null]
  logtypeid     int          [not null, ref: > PV_LogTypes.logtypeid]
  logsourceid   int          [not null, ref: > PV_LogSource.logsourceid]
  logseverityid int          [not null, ref: > PV_LogSeverity.logseverityid]
  value1        varchar(500)
  value2        varchar(500)
}
