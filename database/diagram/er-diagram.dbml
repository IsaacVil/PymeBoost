// ============================================================
// 2. USER DOMAIN
// ============================================================

Table PB_Pymes {
  id              uuid          [pk, default: `gen_random_uuid()`]
  auth0Id         varchar(64)   [not null, unique]
  ownerName       varchar(100)  [not null]
  businessEmail   varchar(150)  [not null, unique]
  phone           varchar(20)   [not null, unique]
  cedulaJuridica  varchar(20)   [not null, unique]
  companyName     varchar(100)  [not null]
  companySizeId   uuid          [not null, ref: > PB_CompanySizes.id]
  industryId      uuid          [ref: > PB_Industries.id]
  description     text
  pymeStatusId    uuid          [not null, ref: > PB_PymeStatus.id]
  reputationScore numeric(12,8) [not null, default: 0]
  ratingCount     integer       [not null, default: 0]
  createdAt       timestamptz   [not null, default: `now()`]
  updatedAt       timestamptz   [not null, default: `now()`]
}

Table PB_Advisors {
  id              uuid          [pk, default: `gen_random_uuid()`]
  auth0Id         varchar(64)   [not null, unique]
  fullName        varchar(100)  [not null]
  displayName     varchar(100)
  personalEmail   varchar(150)  [not null, unique]
  phone           varchar(20)   [not null, unique]
  linkedinUrl     varchar(500)  [not null]
  description     text
  baseRate        numeric(14,2)
  isAvailable     boolean       [not null, default: true]
  advisorStatusId uuid          [not null, ref: > PB_AdvisorStatus.id]
  reputationScore numeric(12,8) [not null, default: 0]
  ratingCount     integer       [not null, default: 0]
  createdAt       timestamptz   [not null, default: `now()`]
  updatedAt       timestamptz   [not null, default: `now()`]
}

Table PB_PymeRoles {
  pymeId     uuid        [not null, ref: > PB_Pymes.id]
  roleId     uuid        [not null, ref: > PB_Roles.id]
  assignedAt timestamptz [not null, default: `now()`]

  indexes {
    (pymeId, roleId) [pk]
  }
}

Table PB_AdvisorRoles {
  advisorId  uuid        [not null, ref: > PB_Advisors.id]
  roleId     uuid        [not null, ref: > PB_Roles.id]
  assignedAt timestamptz [not null, default: `now()`]

  indexes {
    (advisorId, roleId) [pk]
  }
}

Table PB_AdvisorExperiences {
  id          uuid         [pk, default: `gen_random_uuid()`]
  advisorId   uuid         [not null, ref: > PB_Advisors.id]
  roleTitle   varchar(100) [not null]
  company     varchar(100)
  startDate   date
  endDate     date
  description text
  createdAt   timestamptz  [not null, default: `now()`]
}

Table PB_AdvisorCertifications {
  id          uuid         [pk, default: `gen_random_uuid()`]
  advisorId   uuid         [not null, ref: > PB_Advisors.id]
  name        varchar(100) [not null]
  issuer      varchar(100)
  issuedAt    date
  createdAt   timestamptz  [not null, default: `now()`]
}

Table PB_AdvisorIndustries {
  advisorId   uuid        [not null, ref: > PB_Advisors.id]
  industryId  uuid        [not null, ref: > PB_Industries.id]
  createdAt   timestamptz [not null, default: `now()`]

  indexes {
    (advisorId, industryId) [pk]
  }
}

Table PB_AdvisorSubIndustryScores {
  advisorId     uuid         [not null, ref: > PB_Advisors.id]
  subIndustryId uuid         [not null, ref: > PB_SubIndustries.id]
  score         numeric(6,5) [not null]
  updatedAt     timestamptz  [not null, default: `now()`]

  indexes {
    (advisorId, subIndustryId) [pk]
  }
}

Table PB_Sessions {
  id              uuid        [pk, default: `gen_random_uuid()`]
  auth0Id         varchar(64) [not null]
  accountTypeId   uuid        [not null, ref: > PB_AccountTypes.id]
  pymeId          uuid        [ref: > PB_Pymes.id]
  advisorId       uuid        [ref: > PB_Advisors.id]
  sessionStatusId uuid        [not null, ref: > PB_SessionStatus.id]
  ipAddress       varchar(45)
  userAgent       varchar(255)
  issuedAt        timestamptz [not null, default: `now()`]
  lastActivityAt  timestamptz [not null, default: `now()`]
  expiresAt       timestamptz [not null]
  createdAt       timestamptz [not null, default: `now()`]
}

