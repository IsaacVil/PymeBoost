// ============================================================
// 1. CATALOGUES
// ============================================================

Table PB_AccountTypes {
  id          uuid         [pk, default: `gen_random_uuid()`]
  code        varchar(50)  [not null, unique]
  name        varchar(100) [not null]
  description varchar(255)
}

Table PB_Roles {
  id          uuid         [pk, default: `gen_random_uuid()`]
  code        varchar(50)  [not null, unique]
  name        varchar(100) [not null]
  description varchar(255)
  isActive    boolean      [not null, default: true]
  createdAt   timestamptz  [not null, default: `now()`]
}

Table PB_CompanySizes {
  id          uuid         [pk, default: `gen_random_uuid()`]
  code        varchar(50)  [not null, unique]
  name        varchar(100) [not null]
  description varchar(255)
}

Table PB_PymeStatus {
  id          uuid         [pk, default: `gen_random_uuid()`]
  code        varchar(50)  [not null, unique]
  name        varchar(100) [not null]
  description varchar(255)
}

Table PB_AdvisorStatus {
  id          uuid         [pk, default: `gen_random_uuid()`]
  code        varchar(50)  [not null, unique]
  name        varchar(100) [not null]
  description varchar(255)
}

Table PB_Industries {
  id                      uuid         [pk, default: `gen_random_uuid()`]
  code                    varchar(50)  [not null, unique]
  name                    varchar(100) [not null]
  description             varchar(255)
  representativeEmbedding text         [note: 'pgvector vector(768)']
  isActive                boolean      [not null, default: true]
  createdAt               timestamptz  [not null, default: `now()`]
}

Table PB_SubIndustries {
  id                      uuid         [pk, default: `gen_random_uuid()`]
  industryId              uuid         [not null, ref: > PB_Industries.id]
  code                    varchar(50)  [not null, unique]
  name                    varchar(100) [not null]
  description             varchar(255)
  representativeEmbedding text         [note: 'pgvector vector(768)']
  vectorIndex             smallint     [not null, unique]
  isActive                boolean      [not null, default: true]
  createdAt               timestamptz  [not null, default: `now()`]
}

Table PB_ThematicCategories {
  id          uuid         [pk, default: `gen_random_uuid()`]
  code        varchar(50)  [not null, unique]
  name        varchar(100) [not null]
  description varchar(255)
  isRequired  boolean      [not null, default: true]
}

Table PB_DocumentStatus {
  id          uuid         [pk, default: `gen_random_uuid()`]
  code        varchar(50)  [not null, unique]
  name        varchar(100) [not null]
  description varchar(255)
}

Table PB_DocumentTypes {
  id          uuid         [pk, default: `gen_random_uuid()`]
  code        varchar(50)  [not null, unique]
  name        varchar(100) [not null]
  description varchar(255)
}

