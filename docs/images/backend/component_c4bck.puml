@startuml PymeBoost_Backend_C4_Level3
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_TOP_DOWN()

title PymeBoost Backend - C4 Level 3 (Components of the Backend API)

System_Ext(frontend, "PymeBoost Frontend / API Gateway", "Next.js via Cloud API Gateway")

Container_Boundary(app, "Backend API (FastAPI on Cloud Run)") {

    System_Boundary(api_layer, "API Layer") {
        Component(router, "API Router", "FastAPI, main.py, api/routes.py", "Endpoint registration,\nmiddleware, error mapping")
    }

    System_Boundary(domains, "Domains Layer (DDD vertical slices: controllers - services - repositories - models - schemas - events)") {
        Component(d_user, "User", "controllers, services,\nrepositories, models, events", "Accounts, login,\nprofiles, sessions")
        Component(d_advisor, "Advisor", "controllers, services,\nrepositories, models, events", "Reputation, specializations,\nbase rates")
        Component(d_pyme, "Pyme", "controllers, services,\nrepositories, models, events", "Business info, recommendations,\nimpact prediction")
        Component(d_matching, "Matching", "controllers, services,\nrepositories, models, events", "Discovery, swipe decisions,\nmatch creation")
        Component(d_contract, "Contract", "controllers, services,\nrepositories, models, events", "Proposals, counter-offers,\nnegotiation")
        Component(d_comm, "Communication", "controllers, services,\nrepositories, models, events", "Chat access & messaging")
        Component(d_project, "Project", "controllers, services,\nrepositories, models, events", "Lifecycle, milestones,\nhealth monitoring")
        Component(d_review, "Review", "controllers, services,\nrepositories, models, events", "Ratings & feedback")
        Component(d_notification, "Notification", "services, handlers", "Event-driven alerts via\nPub/Sub subscribers")
        Component(d_event, "Event", "services, publishers", "Event audit log &\nPub/Sub publishing")
    }

    System_Boundary(shared, "Shared Kernel") {
        Component(s_auth, "Auth", "jwt_validator,\npermission_checker, auth0_service", "JWT validation, JWKS,\nrole-based authorization")
        Component(s_eventbus, "Event Bus", "event_bus, event_registry,\nevent_handler", "In-process event dispatch")
        Component(s_messaging, "Messaging", "pubsub_client,\npublisher, subscriber", "Cloud Pub/Sub adapter")
        Component(s_persistence, "Persistence", "database connection,\nsession, migrations", "SQLAlchemy session factory,\nrepository base")
        Component(s_cross, "Cross-cutting", "logging, exceptions,\nvalidators, utils, config", "Structured logs, error mapping,\nvalidation, encryption utils")
    }
}

' --- External containers (from Level 2) ---
ContainerDb(db, "Relational DB", "Cloud SQL - PostgreSQL 16")
ContainerDb(redis, "Session Cache", "Memorystore - Redis")
Container(pubsub, "Event Bus", "Cloud Pub/Sub + Cloud Tasks")
ContainerDb(storage, "Object Storage", "Cloud Storage")
System_Ext(auth0, "Auth0", "JWT / JWKS")
System_Ext(document_ai, "Cloud Document AI", "OCR")
System_Ext(langgraph, "LangGraph", "Agent Orchestration")
System_Ext(ops, "Cloud Operations", "Logging / Monitoring / Trace")

' --- Entry ---
Rel(frontend, router, "Sends API requests", "REST + JWT / HTTPS")

' --- Router to domains (representative) ---
Rel_D(router, d_user, "routes to")
Rel_D(router, d_advisor, "routes to")
Rel_D(router, d_pyme, "routes to")
Rel_D(router, d_matching, "routes to")
Rel_D(router, d_contract, "routes to")
Rel_D(router, d_comm, "routes to")
Rel_D(router, d_project, "routes to")
Rel_D(router, d_review, "routes to")

' --- Every request authenticated/authorized ---
Rel(router, s_auth, "validates JWT & role", "per request")

' --- Domains use the shared kernel (representative slices) ---
Rel(d_user, s_persistence, "persists via repositories")
Rel(d_matching, s_persistence, "persists via repositories")
Rel(d_contract, s_persistence, "persists via repositories")
Rel(d_project, s_persistence, "persists via repositories")

Rel(d_contract, s_eventbus, "publishes domain events")
Rel(d_matching, s_eventbus, "publishes domain events")
Rel(d_project, s_eventbus, "publishes domain events")
Rel(d_user, s_eventbus, "publishes domain events")

' --- Event flow out to Pub/Sub and back to handlers ---
Rel(s_eventbus, d_event, "dispatches to audit & publisher")
Rel(d_event, s_messaging, "publishes events")
Rel(s_messaging, pubsub, "publish / subscribe", "gRPC")
Rel(pubsub, d_notification, "delivers events", "subscription")
Rel(d_notification, s_messaging, "consumes events")

' --- Shared kernel to external systems ---
Rel(s_persistence, db, "SQL queries", "SQLAlchemy / TLS")
Rel(s_auth, auth0, "fetches JWKS / validates", "HTTPS")
Rel(s_auth, redis, "caches sessions & JWKS", "Redis")
Rel(d_user, redis, "session cache", "Redis")

' --- Domain-specific external integrations ---
Rel(d_pyme, langgraph, "requests recommendations", "HTTPS")
Rel(d_user, document_ai, "validates documents (OCR)", "HTTPS")
Rel(d_user, storage, "stores legal documents", "HTTPS")

' --- Observability ---
Rel(s_cross, ops, "logs, metrics, traces", "OpenTelemetry")

@enduml
