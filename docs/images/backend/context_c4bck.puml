@startuml context_c4bck
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title PymeBoost Backend — C4 Context Diagram

Person(pyme, "PYME", "Small or medium enterprise owner seeking advisory services.")
Person(advisor, "Advisor", "Business specialist offering consulting services.")

System_Boundary(backend_boundary, "PymeBoost Backend") {
    System(backend, "PymeBoost Backend API", "FastAPI 0.115.4 / Python 3.12\nDomain-Driven Design + Event-Driven Architecture\nHosted on Google Cloud Run")
}

System_Ext(frontend,         "PymeBoost Frontend",           "Next.js 15 / React 19\nHosted on Vercel")
System_Ext(auth0,            "Auth0",                        "OAuth 2.0 / JWT token issuance and validation")
System_Ext(cloud_sql,        "Google Cloud SQL + pgvector",  "PostgreSQL 16\nRelational data + vector similarity search")
System_Ext(redis,            "Google Cloud Memorystore",     "Redis\nSession cache, JWKS cache, recommendation cache")
System_Ext(pubsub,           "Google Cloud Pub/Sub",         "Async domain events, AI processing triggers,\nnotifications and DLQ")
System_Ext(cloud_tasks,      "Google Cloud Tasks",           "Deferred and scheduled async task execution")
System_Ext(cloud_scheduler,  "Google Cloud Scheduler",       "Cron-based trigger for the recommendation\nbatch job (every 24 hours)")
System_Ext(cloud_storage,    "Google Cloud Storage",         "Advisor use case PDFs, project completion\ndocuments and legal files")
System_Ext(document_ai,      "Google Cloud Document AI",     "OCR processing for advisor use case PDFs\nand project completion documents")
System_Ext(proxycurl,        "ProxyCurl API",                "Nubela — extracts structured advisor data\nfrom LinkedIn URL at registration")
System_Ext(hacienda_api,     "Hacienda API",                 "Costa Rica public registry (api.hacienda.go.cr)\nValidates cédula jurídica at SME registration")
System_Ext(langgraph,        "LangGraph",                    "v0.2.41\nAI agent orchestration for advisor\nrecommendation scoring")
System_Ext(secret_manager,   "Google Secret Manager",        "Secure storage for API keys and credentials")
System_Ext(kms,              "Google Cloud KMS",             "Encryption key management for sensitive data")
System_Ext(operations,       "Google Cloud Operations Suite","Cloud Logging + Cloud Monitoring + Cloud Trace\nfor full-stack observability")
System_Ext(api_gateway,      "Google Cloud API Gateway",     "API routing, rate limiting, Cloud Armor WAF")
System_Ext(artifact_registry,"Google Artifact Registry",     "Container image registry for Cloud Run deployments")

' User interactions
Rel(pyme,    frontend, "Uses", "HTTPS")
Rel(advisor, frontend, "Uses", "HTTPS")

' Frontend to backend
Rel(frontend,   api_gateway, "Sends REST requests", "HTTPS + JWT")
Rel(api_gateway, backend,    "Routes requests",      "HTTPS / TLS 1.3")

' Authentication
Rel(backend, auth0, "Validates JWT tokens and fetches JWKS", "HTTPS")

' Data stores
Rel(backend, cloud_sql,   "Reads and writes domain data + vector queries", "SQLAlchemy / pgvector / TCP")
Rel(backend, redis,       "Stores and retrieves session and recommendation cache", "Redis protocol")

' Async messaging and scheduling
Rel(backend,         pubsub,          "Publishes and subscribes to domain events", "gRPC")
Rel(backend,         cloud_tasks,     "Schedules deferred async tasks",            "HTTPS")
Rel(cloud_scheduler, pubsub,          "Fires recommendation batch job trigger",     "HTTP / gRPC")

' Storage and AI
Rel(backend, cloud_storage, "Stores and retrieves PDFs and documents",         "HTTPS")
Rel(backend, document_ai,   "Sends use case and completion PDFs for OCR",      "HTTPS")
Rel(backend, langgraph,     "Orchestrates AI agents for advisor recommendations","HTTPS")

' Third-party integrations
Rel(backend, proxycurl,   "Extracts LinkedIn profile at advisor registration", "HTTPS")
Rel(backend, hacienda_api,"Validates cédula jurídica at SME registration",     "HTTPS")

' Security and secrets
Rel(backend, secret_manager, "Fetches secrets and API keys at runtime", "HTTPS")
Rel(backend, kms,            "Encrypts and decrypts sensitive fields",   "HTTPS")

' Observability
Rel(backend, operations, "Sends structured logs, metrics and traces", "gRPC / OpenTelemetry")

' Deployment
Rel(artifact_registry, backend, "Provides container images", "Docker pull")

@enduml
